generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  name       String
  password   String
  role       String     @default("AGENT")
  avatar     String?
  createdAt  DateTime   @default(now())
  properties  Property[]
  activities  Activity[]
  contacts    Contact[]
  inquiries   Inquiry[]
  deals       Deal[]
  campaigns   Campaign[]
  waTemplates WaTemplate[]
}

model Property {
  id           String      @id @default(cuid())
  title        String
  description  String?
  type         String      @default("CASA")
  operation    String      @default("VENTA")
  status       String      @default("DISPONIBLE")
  price        Float
  currency     String      @default("ARS")
  address      String
  city         String
  neighborhood String?
  bedrooms     Int?
  bathrooms    Int?
  area         Float?
  images       String[]
  features     String[]
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  inquiries    Inquiry[]
  deals        Deal[]
  activities   Activity[]
}

model Contact {
  id         String              @id @default(cuid())
  name       String
  email      String?
  phone      String?
  type       String              @default("COMPRADOR")
  notes      String?
  userId     String?
  user       User?               @relation(fields: [userId], references: [id])
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  inquiries  Inquiry[]
  deals      Deal[]
  activities Activity[]
  recipients CampaignRecipient[]
}

model Inquiry {
  id           String    @id @default(cuid())
  name         String
  email        String?
  phone        String?
  message      String?
  source       String?
  channel      String?
  adName       String?
  formId       String?
  city         String?
  province     String?
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id])
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id])
  status       String     @default("NUEVA")
  assignedTo   String?
  assignedUser User?      @relation(fields: [assignedTo], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  activities   Activity[]
}

model Deal {
  id         String     @id @default(cuid())
  title      String
  contactId  String
  contact    Contact    @relation(fields: [contactId], references: [id])
  propertyId String?
  property   Property?  @relation(fields: [propertyId], references: [id])
  stage      String     @default("VISITA")
  status     String     @default("ACTIVA")
  value      Float?
  notes      String?
  userId     String?
  user       User?      @relation(fields: [userId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  activities Activity[]
}

model Activity {
  id         String    @id @default(cuid())
  title      String
  type       String    @default("LLAMADA")
  date       DateTime
  done       Boolean   @default(false)
  notes      String?
  contactId  String?
  contact    Contact?  @relation(fields: [contactId], references: [id])
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
  dealId     String?
  deal       Deal?     @relation(fields: [dealId], references: [id])
  inquiryId  String?
  inquiry    Inquiry?  @relation(fields: [inquiryId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  createdAt  DateTime  @default(now())
}

model Campaign {
  id         String              @id @default(cuid())
  title      String
  type       String              @default("NEWSLETTER")
  subject    String?
  content    String?
  status     String              @default("BORRADOR")
  sentAt     DateTime?
  userId     String?
  user       User?               @relation(fields: [userId], references: [id])
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  recipients CampaignRecipient[]
}

model WaTemplate {
  id        String   @id @default(cuid())
  name      String
  message   String
  formName  String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignRecipient {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact   @relation(fields: [contactId], references: [id])
  emailId    String?
  sentAt     DateTime?
  opened     Boolean   @default(false)
  openedAt   DateTime?
  clicked    Boolean   @default(false)
  clickedAt  DateTime?
  error      String?
}
